# Copy to .env.deploy on the server and fill in the secrets.
#   cp .env.deploy.example .env.deploy
# Generate APP_KEY with:
#   docker run --rm dunglas/frankenphp:1-php8.4 php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
# (or `php artisan key:generate --show` if PHP is available locally)

APP_NAME="Dashboard Skripsi Gangguan Jaringan"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://angga.jagat-grafika.com:8090

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

# App talks to the bundled MySQL service ("db") on the private skripsi-net.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=skripsi
DB_USERNAME=skripsi
DB_PASSWORD=change-me-to-a-strong-password

# The MySQL container initialises itself from these. Keep them identical to the
# DB_* values above (DB_DATABASE/DB_USERNAME/DB_PASSWORD).
MYSQL_DATABASE=skripsi
MYSQL_USER=skripsi
MYSQL_PASSWORD=change-me-to-a-strong-password
MYSQL_ROOT_PASSWORD=change-me-to-a-strong-root-password

# No Redis on this box for our app — keep everything on file/database.
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
